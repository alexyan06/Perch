{
  "name": "app",
  "private": true,
  "version": "0.1.0",
  "description": "Electron + React desktop app — main process owns OS access, renderer is the UI.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "postinstall": "node scripts/prepare-panel-window.js && electron-rebuild -f --only better-sqlite3,@ashubashir/electron-panel-window"
  },
  "dependencies": {
    "@ashubashir/electron-panel-window": "1.0.19",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-scroll-area": "^1.2.15",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.13",
    "active-win": "7",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jimp": "^1.6.1",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.2",
    "openai": "^6.46.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
