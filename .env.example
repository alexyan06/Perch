# Copy to .env and fill in real values. Never commit .env itself.

# Used for vision escalation and task-aware nudge copy. Get one at
# https://platform.openai.com/api-keys.
OPENAI_API_KEY=your_openai_api_key_here

# Used only for optional custom mascot photo generation with Nano Banana Pro.
# Get one at https://aistudio.google.com/app/apikey.
GEMINI_API_KEY=your_gemini_api_key_here

# Local WebSocket port the Electron app listens on, and the extension connects to.
# Keep this in sync between app/ and extension/ configs — see docs/ipc-contract.md.
WS_PORT=8743
